# ===========================================
# Roubômetro Batch — Variáveis de Ambiente
# ===========================================
# Copie este arquivo para .env e preencha com os valores reais.
# O .env NUNCA deve ser commitado no Git.

# Banco de dados (produção — hospedagem externa)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=roubometro
DB_USER=usuario
DB_PASSWORD=senha

# Banco de dados local (Docker Compose — dev)
# Usado quando profile=local
DB_LOCAL_HOST=localhost
DB_LOCAL_PORT=3306
DB_LOCAL_NAME=roubometro_dev
DB_LOCAL_USER=root
DB_LOCAL_PASSWORD=root

# Spring Batch
SPRING_BATCH_JOB_ENABLED=false

# Configurações do portal (scraping)
PORTAL_URL=https://dados.gov.br/dados/conjuntos-dados/isp-estatisticas-de-seguranca-publica
DOWNLOAD_TIMEOUT_SECONDS=60
CSV_STORAGE_PATH=./data/csv
